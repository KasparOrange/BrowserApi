<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <LangVersion>latest</LangVersion>
        <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
        <IsRoslynComponent>true</IsRoslynComponent>
        <RootNamespace>BrowserApi.SourceGen</RootNamespace>
        <Description>Roslyn source generator that creates typed C# wrappers from JavaScript modules with JSDoc comments.</Description>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="BrowserApi.SourceGen.Tests" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" Version="3.3.*" PrivateAssets="all" />
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.*" PrivateAssets="all" />
    </ItemGroup>

</Project>
