<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <RootNamespace>BrowserApi</RootNamespace>
        <Description>Typed C# wrappers for browser APIs. Zero dependencies — pure types, CSS values, DOM interfaces, and enums generated from W3C WebIDL specs.</Description>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);CS1591;CS1574;CS1580;CS1584;CS0419</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="BrowserApi.JSInterop" />
        <InternalsVisibleTo Include="BrowserApi.Blazor" />
        <InternalsVisibleTo Include="BrowserApi.Runtime" />
        <InternalsVisibleTo Include="BrowserApi.Tests" />
    </ItemGroup>

</Project>
