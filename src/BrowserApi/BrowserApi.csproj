<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <PackageId>BrowserApi</PackageId>
        <Version>0.1.0</Version>
        <RootNamespace>BrowserApi</RootNamespace>
        <Description>Typed C# wrappers for every browser API — DOM, CSS, Canvas, Fetch, Storage, Events, Animations. 2,693 types generated from W3C/WHATWG WebIDL specs. Zero dependencies.</Description>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <NoWarn>$(NoWarn);CS1591;CS1574;CS1580;CS1584;CS0419</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <InternalsVisibleTo Include="BrowserApi.JSInterop" />
        <InternalsVisibleTo Include="BrowserApi.Blazor" />
        <InternalsVisibleTo Include="BrowserApi.Runtime" />
        <InternalsVisibleTo Include="BrowserApi.Tests" />
    </ItemGroup>

</Project>
